{
  "name": "gestimus-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend Postgres + Fastify + Drizzle per Gestimus",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:bootstrap": "tsx scripts/bootstrap-db.ts",
    "db:push": "drizzle-kit push",
    "db:policies": "tsx scripts/apply-policies.ts",
    "db:setup": "npm run db:push && npm run db:policies",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-dev.ts",
    "db:seed:prod": "tsx scripts/seed-prod.ts",
    "db:reset": "SEED_RESET=1 tsx scripts/seed-dev.ts",
    "db:sql:status": "tsx scripts/migrate.ts status",
    "db:sql:up": "tsx scripts/migrate.ts up",
    "db:sql:down": "tsx scripts/migrate.ts down",
    "db:sql:baseline": "tsx scripts/migrate.ts baseline",
    "db:backup": "tsx scripts/backup.ts",
    "test": "node --test --test-concurrency=1 --test-force-exit --import tsx tests/rls/*.test.ts tests/auth/*.test.ts tests/crud/*.test.ts tests/realtime/*.test.ts",
    "test:realtime": "node --test --test-force-exit --import tsx tests/realtime/*.test.ts",
    "test:triggers": "node --test --test-force-exit --import tsx tests/crud/triggers.test.ts",
    "test:privacy": "node --test --test-force-exit --import tsx tests/crud/privacy.test.ts",
    "test:rls": "node --test --test-force-exit --import tsx tests/rls/*.test.ts",
    "test:auth": "node --test --test-force-exit --import tsx tests/auth/*.test.ts",
    "test:crud": "node --test --test-force-exit --import tsx tests/crud/*.test.ts",
    "lint": "tsc -p tsconfig.lint.json"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/static": "^9.1.3",
    "@node-rs/argon2": "^2.0.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@sentry/node": "^10.53.1",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
