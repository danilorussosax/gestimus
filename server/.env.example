# Database
DATABASE_URL_APP=postgres://gestimus_app:devpassword@localhost:5432/gestimus
DATABASE_URL_SUPER=postgres://gestimus_super:devpassword@localhost:5432/gestimus

# Server
PORT=4000
HOST=127.0.0.1
NODE_ENV=development
LOG_LEVEL=debug

# Tenant resolution (subdomain del super-admin)
SUPERADMIN_SUBDOMAIN=platform

# Cookie session (Fase 1, non usato ancora)
SESSION_COOKIE_NAME=gestimus_session
SESSION_COOKIE_SECRET=changeme-dev-secret-min-32-chars-long-xxxxx

# Cifratura SMTP (riusata da pb_hooks/tenants.pb.js logic)
GESTIMUS_SECRET_KEY=changeme-32-byte-hex-string-aaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Storage uploads (filesystem locale)
UPLOADS_DIR=./uploads
UPLOADS_MAX_FILE_SIZE_MB=5

# Platform SMTP fallback (usato se il tenant non ha SMTP configurato)
# PLATFORM_SMTP_HOST=smtp.example.com
# PLATFORM_SMTP_PORT=587
# PLATFORM_SMTP_USER=noreply@example.com
# PLATFORM_SMTP_PASSWORD=
# PLATFORM_SMTP_FROM=Gestimus <noreply@example.com>
