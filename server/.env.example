# Database
DATABASE_URL_APP=postgres://gestimus_app:devpassword@localhost:5432/gestimus
DATABASE_URL_SUPER=postgres://gestimus_super:devpassword@localhost:5432/gestimus
# DSN DIRETTO a Postgres (no PgBouncer). Usato solo da LISTEN/NOTIFY (realtime) e
# dall'advisory lock di sessione del cleanup. Se assente, ricade su SUPER.
# DATABASE_URL_DIRECT=postgres://gestimus_super:devpassword@localhost:5432/gestimus

# Dimensione pool connessioni (default node-pg = 10). Vedi docs/DEPLOY-IONOS.md § PgBouncer.
DB_APP_POOL_MAX=20
DB_SUPER_POOL_MAX=5
# Con PgBouncer (transaction mode): APP e SUPER possono entrambi passare dal
# bouncer (sono transaction-scoped); SOLO DATABASE_URL_DIRECT resta sul :5432.
#   DATABASE_URL_APP    → PgBouncer (es. :6432)
#   DATABASE_URL_SUPER  → PgBouncer (es. :6432)
#   DATABASE_URL_DIRECT → Postgres diretto (:5432)   ← LISTEN/NOTIFY + lock di sessione

# Server
PORT=4000
HOST=127.0.0.1
NODE_ENV=development
LOG_LEVEL=debug

# Tenant resolution (subdomain del super-admin)
SUPERADMIN_SUBDOMAIN=platform

# Cookie session (Fase 1, non usato ancora)
SESSION_COOKIE_NAME=gestimus_session
SESSION_COOKIE_SECRET=changeme-dev-secret-min-32-chars-long-xxxxx

# Cifratura SMTP (riusata da pb_hooks/tenants.pb.js logic)
GESTIMUS_SECRET_KEY=changeme-32-byte-hex-string-aaaaaaaaaaaaaaaaaaaaaaaaaaaa
# Rotazione chiave (#2): valorizzare con il VECCHIO GESTIMUS_SECRET_KEY durante
# una rotazione. decrypt SMTP/backup e verifica firme audit/MFA ritentano con
# questa se la corrente fallisce → niente dato cifrato/firmato perso. Rimuovere
# dopo aver re-cifrato/re-firmato tutto con la chiave nuova.
# GESTIMUS_SECRET_KEY_PREVIOUS=

# Storage uploads (filesystem locale)
UPLOADS_DIR=./uploads
UPLOADS_MAX_FILE_SIZE_MB=5

# Platform SMTP fallback (usato se il tenant non ha SMTP configurato)
# PLATFORM_SMTP_HOST=smtp.example.com
# PLATFORM_SMTP_PORT=587
# PLATFORM_SMTP_USER=noreply@example.com
# PLATFORM_SMTP_PASSWORD=
# PLATFORM_SMTP_FROM=Gestimus <noreply@example.com>
