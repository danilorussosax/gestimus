# ============================================================================
# Gestimus — .gitignore
# Esclude: dati runtime, binari, dipendenze, file di sistema/IDE, screenshot.
# ============================================================================

# ---- Sistema operativo ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---- Dipendenze ----
node_modules/
package-lock.json.bak

# ---- PocketBase: binario + dati runtime (DB, attachments) + doc del binario ----
# NON committare il binario (40+ MB) né i dati dei tenant locali.
pocketbase/pocketbase
pocketbase/pb_data
pocketbase/pb_data_*
pocketbase/_archive/
pocketbase/CHANGELOG.md
pocketbase/LICENSE.md

# ---- Backup / archivi locali ----
backups/
*.bak
*.backup
*.dump

# ---- Test artifacts ----
test-results/
playwright-report/
blob-report/
coverage/
.nyc_output/

# ---- Log ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Editor / IDE ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Variabili di ambiente sensibili ----
.env
.env.local
.env.*.local
*.pem
*.key
*.cert
secrets/

# ---- Claude / agenti ----
.claude/
memory/

# ---- Asset temporanei locali (sostituiti dal logo finale ente-by-ente) ----
logo-hold.png

# ---- Documenti binari grossi (mantieni solo se servono in repo) ----
# Schema_*.docx è documentazione → INCLUDILO se serve come reference
# screen.png, sfondo.png → asset frontend, INCLUDILI
