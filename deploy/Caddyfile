# Caddyfile per deploy multitenant del Gestionale Concorso Musicale
#
# Ogni tenant (ente organizzatore) ha un sottodominio e un'istanza
# PocketBase dedicata su una porta separata. Il frontend statico
# è condiviso tra tutti i tenant.
#
# Requisiti:
#   - DNS wildcard: *.concorso.app → IP del server
#   - Certificati TLS: Caddy li gestisce automaticamente con on-demand TLS
#   - PocketBase: una istanza per tenant (pb@<slug>.service)
#
# Per aggiungere un tenant, aggiungere un blocco handler e ricaricare:
#   systemctl reload caddy

# --- Configurazione globale ---
{
    # Per on-demand TLS, Caddy verifica che il dominio sia autorizzato
    # prima di emettere un certificato. La URL punta a un endpoint del
    # super-admin che risponde 200 solo per i tenant registrati.
    on_demand_tls {
        ask http://localhost:8090/api/tenants/check-domain
    }
}

# --- Tenant: conservatorio-milano ---
conservatorio-milano.concorso.app {
    tls { on_demand }
    root * /var/www/gestionale
    @api path /api/* /_/*
    reverse_proxy @api localhost:8091
    file_server
}

