# Configurazione di deploy per il dominio gestimus.it
# Sourcable: `source /opt/gestimus/deploy/gestimus.env`
# Le variabili definite qui sono usate dagli script di provisioning e propagazione.

# ---- Dominio principale ----
export DOMAIN_BASE="gestimus.it"
# Sottodominio dedicato al super admin (pannello "Gestione Enti")
export PLATFORM_DOMAIN="platform.${DOMAIN_BASE}"
# Pattern wildcard usato per i tenant: <slug>.${DOMAIN_BASE}
# (es. liceo-musicale-milano.gestimus.it)

# ---- Email amministrative ----
# Email tecnica per Let's Encrypt + alerts certbot
export LE_EMAIL="admin@${DOMAIN_BASE}"
# Email del super admin della piattaforma
export SUPERADMIN_EMAIL="superadmin@${PLATFORM_DOMAIN}"

# ---- URL pubblici ----
# Usati negli script di propagazione e nelle email transazionali.
export PLATFORM_URL="https://${PLATFORM_DOMAIN}"
export APP_URL_PATTERN="https://%SLUG%.${DOMAIN_BASE}"   # %SLUG% sostituito a runtime

# ---- Path filesystem ----
export PB_BIN="/srv/pb/pocketbase"
export PB_DATA_ROOT="/srv/pb/data"
export PB_ARCHIVE_ROOT="/srv/pb/archive"
export PB_MIGRATIONS="/srv/pb/pb_migrations"
export PB_HOOKS="/srv/pb/pb_hooks"
export ENV_DIR="/etc/pb"
export WWW_DIR="/var/www/gestimus"

# ---- Reverse proxy ----
# I path dei file nginx per ogni tenant
export NGINX_SITES_AVAILABLE="/etc/nginx/sites-available"
export NGINX_SITES_ENABLED="/etc/nginx/sites-enabled"

# ---- Chiave di cifratura applicativa ----
# Usata da pb_hooks/tenants.pb.js per cifrare lo storage di `smtp_password`.
# Genera una chiave random (32+ char):  openssl rand -hex 32
# Deve essere ESPORTATA nell'ambiente del PB della piattaforma (8093). Esempio
# in /etc/pb/platform.env:
#   GESTIMUS_SECRET_KEY=<lunga-stringa-random>
# ATTENZIONE: cambiarla rende illeggibili le password SMTP salvate prima del cambio.
# export GESTIMUS_SECRET_KEY="<inserire-32+chars>"

# ---- Range porte PocketBase per tenant ----
# Le porte sono assegnate in modo crescente partendo da PB_PORT_START.
# 8093 è riservata al PB della piattaforma (super admin).
export PB_PORT_PLATFORM="8093"
export PB_PORT_START="8091"
export PB_PORT_END="9999"
